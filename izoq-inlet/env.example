# ─── IZOQ Inlet — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your real keys before deploying
# Never commit .env to GitHub — it is already in .gitignore

# ── Sumsub KYB/KYC ──────────────────────────────────────────────────────────
VITE_SUMSUB_APP_TOKEN=your_sumsub_app_token_here
VITE_SUMSUB_SECRET_KEY=your_sumsub_secret_key_here

# ── Smile ID / Dojah (Nigeria identity) ─────────────────────────────────────
VITE_SMILEID_API_KEY=your_smileid_api_key_here
VITE_DOJAH_APP_ID=your_dojah_app_id_here
VITE_DOJAH_API_KEY=your_dojah_api_key_here

# ── IZOQ Backend API ─────────────────────────────────────────────────────────
VITE_IZOQ_API_URL=https://api.izoq.io
VITE_IZOQ_LIVE_KEY=izoq_live_sk_your_real_key_here
VITE_IZOQ_TEST_KEY=izoq_test_sk_your_real_key_here

# ── Blockchain RPC (Alchemy / QuickNode) ─────────────────────────────────────
VITE_ALCHEMY_API_KEY=your_alchemy_api_key_here
VITE_ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_key
VITE_SOL_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/your_key

# ── Settlement (Flutterwave / Paystack) ──────────────────────────────────────
VITE_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_your_key_here
VITE_PAYSTACK_PUBLIC_KEY=pk_live_your_key_here

# ── Environment ───────────────────────────────────────────────────────────────
VITE_ENV=production
